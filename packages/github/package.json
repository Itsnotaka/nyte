{
  "name": "@nyte/github",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf .turbo .cache node_modules dist"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "neverthrow": "^8.2.0",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@nyte/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "typescript": "6.0.0-beta"
  }
}
