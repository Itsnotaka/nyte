{
  "extends": "@nyte/tsconfig/base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["es2023", "dom", "dom.iterable"],
    "moduleResolution": "bundler",
    "paths": {
      "*": ["./*"],
      "~/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", ".cache", "dist"]
}
